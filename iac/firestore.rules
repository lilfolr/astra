rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function getStarshipData(starshipId) {
      return get(/databases/$(database)/documents/api/v1/starships/$(starshipId)).data;
    }

    function isCaptain(starshipId) {
      return isAuthenticated() &&
        (getStarshipData(starshipId).primaryCaptainId == request.auth.uid);
    }

    // A user is a member if they have a mapping in userStarships pointing to this starship.
    function isMemberOfStarship(starshipId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/api/v1/userStarships/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/api/v1/userStarships/$(request.auth.uid)).data.starshipId == starshipId;
    }

    // --- Collections ---

    // User to Starship mapping (1:1)
    match /api/v1/userStarships/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Starships
    match /api/v1/starships/{starshipId} {
      // Members can read starship details.
      // Also allow get for discovery purposes before the mapping is established.
      allow get: if isAuthenticated();

      // Queries must be filtered by membership or captaincy.
      allow list: if isAuthenticated() && (
        resource.data.primaryCaptainId == request.auth.uid ||
        isMemberOfStarship(starshipId)
      );

      allow create: if isAuthenticated() && request.resource.data.primaryCaptainId == request.auth.uid;
      allow update: if isCaptain(starshipId);
      allow delete: if false;

      // Modules (Rooms)
      match /modules/{moduleId} {
        allow read: if isAuthenticated() && (isMemberOfStarship(starshipId) || isCaptain(starshipId));
        allow write: if isCaptain(starshipId);
      }

      // Missions (Chores)
      match /missions/{missionId} {
        allow read: if isAuthenticated() && (isMemberOfStarship(starshipId) || isCaptain(starshipId));
        allow create: if isCaptain(starshipId);
        allow update: if isCaptain(starshipId) || (
          isAuthenticated() && (isMemberOfStarship(starshipId) || isCaptain(starshipId)) && (
            // Crew member can update their assigned mission to active or under_review
            (resource.data.assignedTo == request.auth.uid &&
             request.resource.data.status in ['active', 'under_review']) ||
            // Verification: A different member can mark a mission as completed
            (resource.data.status == 'under_review' &&
             request.resource.data.status == 'completed' &&
             resource.data.assignedTo != request.auth.uid)
          )
        );
        allow delete: if isCaptain(starshipId);
      }

      // Crew members
      match /crew/{crewId} {
        // Allow get for joining via registration code.
        allow get: if isAuthenticated();
        // Roster is visible to members.
        allow list: if isAuthenticated() && (isMemberOfStarship(starshipId) || isCaptain(starshipId));

        allow create: if isCaptain(starshipId);

        allow update: if isCaptain(starshipId) || (
          isAuthenticated() && (
            // Regular updates (e.g., lastSeen) for the specific user
            resource.data.uid == request.auth.uid ||
            // Join process: linking the UID to a pending slot
            (
              (resource.data.uid == null || resource.data.uid == "") &&
              request.resource.data.uid == request.auth.uid &&
              resource.data.registrationCodeExpiry > request.time.toMillis()
            )
          )
        );
        allow delete: if isCaptain(starshipId);
      }
    }

    // Collection Group rule for crew lookup during discovery
    match /{path=**}/crew/{crewId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
